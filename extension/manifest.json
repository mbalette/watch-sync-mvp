{
  "manifest_version": 3,
  "name": "Watch Sync Local Auto-sync MVP",
  "description": "Pairs the active Chrome tab's HTML5 video with a local Watch Sync room.",
  "version": "0.1.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["ws://127.0.0.1/*", "ws://localhost/*"],
  "action": {
    "default_title": "Watch Sync",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service_worker.js"
  }
}
