{
  "name": "watch-sync-mvp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:realtime": "tsx server/realtime.ts",
    "dev:tv-remote": "tsx server/tv-remote-helper.ts",
    "dev:all": "concurrently -k -n vite,realtime \"npm run dev\" \"npm run dev:realtime\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "smoke:realtime": "tsx server/smoke-realtime.ts",
    "smoke:realtime:prod": "tsx server/smoke-production-realtime.ts",
    "deploy:realtime:cloudflare": "wrangler deploy --config wrangler.realtime.toml",
    "build:prod": "VITE_REALTIME_URL=wss://api.kyrosdirect.tech npm run build",
    "lan:help": "tsx scripts/lan-help.ts",
    "package:extension": "tsx scripts/package-extension.ts",
    "typecheck": "tsc --noEmit",
    "test:remote-start-beta": "vitest run src/tv-remote-device.test.ts",
    "test:remote-start-runtime-beta": "vitest run src/tv-remote-device.test.ts",
    "test:remote-start-runtime-beta:all-platforms": "vitest run src/tv-remote-device.test.ts server/tv-remote-helper.test.ts server/vizio-smartcast-remote.test.ts server/lg-webos-remote.test.ts server/samsung-tizen-remote.test.ts server/sony-bravia-remote.test.ts",
    "test:remote-start-simulator": "vitest run src/remote-start-simulator/index.test.ts && tsx scripts/remote-start-simulator-export.ts",
    "remote-start:summary": "tsx scripts/remote-start-summary.ts",
    "remote-start:events:export": "tsx scripts/remote-start-events-export.ts",
    "remote-start:events:prune": "tsx scripts/remote-start-events-prune.ts"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsx": "^4.20.6",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "playwright": "^1.59.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.0.15"
  }
}
